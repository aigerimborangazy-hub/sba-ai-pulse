# SBA AI Pulse — Environment Variables
# Copy this file to .env.local and fill in the values.

# OpenRouter API key (required for LLM news gathering)
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Secret token to protect the /api/refresh endpoint
# Generate a random string, e.g.: openssl rand -hex 32
CRON_SECRET=

# Optional: expose the CRON_SECRET to the client-side refresh button
# (Only needed if you want the UI "Refresh" button to work in production)
# For local development, you can also set this to the same value as CRON_SECRET
NEXT_PUBLIC_CRON_SECRET=
